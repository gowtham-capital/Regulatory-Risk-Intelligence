# Regulatory Risk Intelligence — API Credentials Template
# SECURITY: Never commit real API keys to GitHub
# Copy this file to .env and replace with your actual API keys
# All variable names MUST start with VITE_ to be accessible in the React app

# Congress.gov API — tracks bills mentioning companies
VITE_CONGRESS_GOV_API_KEY=your_congress_api_key_here

# FCC ECFS API — tracks open FCC proceedings
VITE_FCC_API_KEY=your_fcc_api_key_here

# NewsAPI — regulatory news coverage from 80,000+ sources
VITE_NEWS_API_KEY=your_news_api_key_here

# Anthropic Claude API — AI analysis layer
VITE_ANTHROPIC_API_KEY=your_claude_api_key_here

# LegiScan API — state-level legislation
VITE_LEGISCAN_API_KEY=your_legiscan_api_key_here

# These APIs require NO keys — called directly:
# Federal Register: https://www.federalregister.gov/api/v1/documents.json
# Senate LDA: https://lda.senate.gov/api/v1/filings/
# FTC RSS Feed: https://www.ftc.gov/feeds/press-release-rss.xml
