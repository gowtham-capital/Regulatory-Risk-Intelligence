# US Geopolitical Media Risk Intelligence — API Credentials Template
# SECURITY: Copy this file to .env and fill in your actual API keys
# Never commit the .env file to GitHub or share it publicly
# All variable names MUST start with VITE_ to be accessible
# in the React app via import.meta.env.VITE_[NAME]

# Congress.gov API — tracks bills mentioning media/streaming companies
VITE_CONGRESS_GOV_API_KEY=your_congress_gov_api_key_here

# FCC ECFS API — tracks open FCC proceedings on video/broadcast/streaming
VITE_FCC_API_KEY=your_fcc_api_key_here

# NewsAPI — regulatory news coverage from 80,000+ sources
VITE_NEWS_API_KEY=your_news_api_key_here

# Anthropic Claude API — AI analysis layer (generates the risk brief)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LegiScan API — state-level legislation (optional)
VITE_LEGISCAN_API_KEY=your_legiscan_api_key_here

# These APIs require NO keys — called directly:
# Federal Register: https://www.federalregister.gov/api/v1/documents.json
# Senate LDA: https://lda.senate.gov/api/v1/filings/
# FTC RSS Feed: https://www.ftc.gov/feeds/press-release-rss.xml
